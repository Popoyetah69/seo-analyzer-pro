# Configuration de SEO Analyzer Pro

# ===== STRIPE CONFIGURATION =====
# Récupérer vos clés sur: https://dashboard.stripe.com/apikeys (TEST MODE)
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
STRIPE_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_WEBHOOK_SECRET_HERE

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# ===== Database Configuration =====
DATABASE_URL=postgresql://user:password@db:5432/seo_analyzer
# Pour développement local: sqlite:///./seoanalyzer.db

# ===== JWT Authentication =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ===== Pricing Configuration =====
PRICING_FREE_REQUESTS=100
PRICING_PRO_PRICE=29
PRICING_PRO_REQUESTS=5000
PRICING_ENTERPRISE_PRICE=99
PRICING_ENTERPRISE_REQUESTS=50000

# ===== Email Configuration (optionnel) =====
# SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
ADMIN_EMAIL=admin@seoanalyzerpro.com

# Stripe Configuration (for payments)
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# External APIs (when implemented)
GOOGLE_API_KEY=your-google-api-key
SEMRUSH_API_KEY=your-semrush-key
AHREFS_API_KEY=your-ahrefs-key

# Feature Flags
ENABLE_REAL_KEYWORD_DATA=False
ENABLE_STRIPE_PAYMENTS=False
ENABLE_EMAIL_NOTIFICATIONS=False
ENABLE_RATE_LIMITING=True

# Security
SECRET_KEY=your-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
MAX_BATCH_SIZE=100

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
